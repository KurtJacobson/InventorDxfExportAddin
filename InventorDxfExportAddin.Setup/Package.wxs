<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Inventor DXF Export Addin"
           Manufacturer="Schröder"
           Version="1.0.0"
           UpgradeCode="{3F7A9B2E-4C6D-4E8F-A1B3-D5C7E9F20134}">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Inventor DXF Export Addin is already installed." />

    <!--
      Install to %ProgramData%\Autodesk\ApplicationPlugins\InventorDxfExport\.
      Inventor scans this directory for .addin manifest files on startup.
      The Assembly path in the .addin is relative, so the DLL must live in the same folder.
    -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="AutodeskDir" Name="Autodesk">
        <Directory Id="ApplicationPluginsDir" Name="ApplicationPlugins">
          <Directory Id="INSTALLDIR" Name="InventorDxfExport">

            <Component Id="AddinFiles" Guid="*">
              <File Source="$(var.AddinOutputDir)\InventorDxfExportAddin.addin" KeyPath="yes" />
              <File Source="$(var.AddinOutputDir)\InventorDxfExportAddin.dll" />
              <File Source="$(var.AddinOutputDir)\InventorDxfExportAddin.deps.json" />
              <File Source="$(var.AddinOutputDir)\InventorDxfExportAddin.dll.config" />
              <File Source="$(var.AddinOutputDir)\IxMilia.Dxf.dll" />
              <File Source="$(var.AddinOutputDir)\IxMilia.Dxf.xml" />
            </Component>

            <Directory Id="ConfigDir" Name="config">
              <Component Id="ConfigFiles" Guid="*">
                <File Source="$(var.AddinOutputDir)\config\export.txt" KeyPath="yes" />
              </Component>
            </Directory>

          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Inventor DXF Export Addin" Level="1">
      <ComponentRef Id="AddinFiles" />
      <ComponentRef Id="ConfigFiles" />
    </Feature>

  </Package>
</Wix>
